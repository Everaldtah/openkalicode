{
  "name": "@openkaliclaude/core",
  "version": "2.0.0",
  "description": "OpenKaliClaude - AI-Powered Cybersecurity CLI Framework with 300+ Kali Linux Tools Integration",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "okal": "./bin/okal",
    "openkaliclaude": "./bin/openkaliclaude",
    "okcli": "./bin/okcli"
  },
  "scripts": {
    "build": "tsc && chmod +x bin/*",
    "dev": "npm run build && node ./dist/cli.mjs",
    "dev:secure": "npm run build && OKAL_SECURE_MODE=1 node ./dist/cli.mjs",
    "install:tools": "node ./dist/scripts/install-security-tools.mjs",
    "verify:tools": "node ./dist/scripts/verify-installation.mjs",
    "mcp:server": "node ./dist/mcp/security-server.mjs",
    "docker:build": "docker build -f container/Dockerfile.kali -t openkaliclaude:latest .",
    "docker:run": "docker run -it --rm openkaliclaude:latest",
    "test": "vitest run",
    "test:security": "vitest run tests/security",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "cybersecurity",
    "penetration-testing",
    "kali-linux",
    "security-tools",
    "nmap",
    "metasploit",
    "ai-agent",
    "mcp",
    "cli",
    "ethical-hacking"
  ],
  "author": "OpenKaliClaude Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openkaliclaude/core"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@types/node": "^20.10.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "fast-xml-parser": "^4.3.2",
    "figlet": "^1.7.0",
    "ink": "^4.4.1",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "react": "^18.2.0",
    "simple-git": "^3.21.0",
    "ws": "^8.14.2",
    "yaml": "^2.3.4",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.4"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/react": "^18.2.43",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "optionalDependencies": {
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0"
  }
}
